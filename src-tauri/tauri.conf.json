{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AI App Builder Studio",
  "version": "0.1.42",
  "identifier": "com.fluxcodex.aiappbuilder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd sidecar && npx tsc && cd .. && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI App Builder Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../updater.json",
      "../sidecar/dist/**/*",
      "../sidecar/node_modules/**/*",
      "../sidecar/prisma/**/*",
      "../sidecar/package.json",
      "resources/node/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4NTMxODgxRUZEOUM0RkQKUldUOXhObnZnUmhUV0ZUK2dWY0VSM2RVK1l1dlNEODloUEdlcmxPVkMwRjFHZW5YVlgxdzBhaGsK"
    }
  }
}
