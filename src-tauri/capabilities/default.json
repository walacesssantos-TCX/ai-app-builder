{
  "identifier": "default",
  "description": "Default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "cmd",
          "cmd": "cmd.exe",
          "args": true
        },
        {
          "name": "bash",
          "cmd": "bash",
          "args": true
        },
        {
          "name": "sh",
          "cmd": "sh",
          "args": true
        }
      ]
    },
    "shell:allow-spawn",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
